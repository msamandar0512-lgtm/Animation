<!DOCTYPE html><html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Bouncing Objects</title>
<style>
body{
  margin:0;
  overflow:hidden;
  background: linear-gradient(270deg,#0d6efd,#6610f2,#0dcaf0,#6f42c1);
  height:100vh;
}
.object{
  position:absolute;
  font-size:50px;
}
</style>
</head>
<body><div class="object">⚽</div>
<div class="object">🚀</div>
<div class="object">🎈</div>
<div class="object">🛸</div>
<div class="object">⭐</div>
<div class="object">🚗</div>
<div class="object">🪐</div>
<div class="object">🎮</div>
<div class="object">✈️</div>
<div class="object">🏀</div><script>
const objects = document.querySelectorAll('.object');
const width = window.innerWidth;
const height = window.innerHeight;

let items = [];
objects.forEach(obj => {
  const item = {
    el: obj,
    x: Math.random()*width,
    y: Math.random()*height,
    vx: (Math.random()-0.5)*6,
    vy: (Math.random()-0.5)*6
  };
  obj.style.left = item.x + 'px';
  obj.style.top = item.y + 'px';
  items.push(item);
});

function animate(){
  items.forEach(item => {
    item.x += item.vx;
    item.y += item.vy;

    if(item.x <=0 || item.x + 50 >= width) item.vx*=-1;
    if(item.y <=0 || item.y + 50 >= height) item.vy*=-1;

    item.el.style.left = item.x + 'px';
    item.el.style.top = item.y + 'px';
  });
  requestAnimationFrame(animate);
}
animate();
</script></body>
</html>
